#!/usr/bin/env bash
# ============================================================
# BF GIT GUARDIAN - Pre-Commit Hook
# Blocks commits containing personal/sensitive data patterns.
#
# Install: python .github/hooks/install-hooks.py
# Config:  .github/.sensitive-patterns
# Bypass:  git commit --no-verify (use with caution)
#
# By Begine Fusion (beginefusion.com)
# ============================================================

RED='\033[0;31m'
YELLOW='\033[1;33m'
GREEN='\033[0;32m'
NC='\033[0m'
BOLD='\033[1m'

PATTERNS_FILE="$(git rev-parse --show-toplevel)/.github/.sensitive-patterns"
BLOCKED=0
WARNINGS=0

echo ""
echo -e "${BOLD}[BF Git Guardian] Scanning staged files...${NC}"
echo ""

if [ ! -f "$PATTERNS_FILE" ]; then
    echo -e "${YELLOW}[WARN] No .sensitive-patterns file found. Skipping scan.${NC}"
    echo -e "${YELLOW}       Create one at: .github/.sensitive-patterns${NC}"
    exit 0
fi

# Get list of staged files (excluding deleted files)
STAGED_FILES=$(git diff --cached --name-only --diff-filter=d)

if [ -z "$STAGED_FILES" ]; then
    exit 0
fi

# ---- PATTERN SCANNING ----

while IFS= read -r line || [ -n "$line" ]; do
    # Skip comments and empty lines
    [[ "$line" =~ ^#.*$ ]] && continue
    [[ "$line" =~ ^[[:space:]]*$ ]] && continue

    # Parse severity
    SEVERITY="BLOCK"
    PATTERN="$line"

    if [[ "$line" =~ ^WARN:[[:space:]]*(.*) ]]; then
        SEVERITY="WARN"
        PATTERN="${BASH_REMATCH[1]}"
    elif [[ "$line" =~ ^BLOCK:[[:space:]]*(.*) ]]; then
        SEVERITY="BLOCK"
        PATTERN="${BASH_REMATCH[1]}"
    fi

    # Search staged file contents
    for file in $STAGED_FILES; do
        # Skip the patterns file itself and binary files
        [[ "$file" == ".github/.sensitive-patterns" ]] && continue
        [[ "$file" =~ \.(png|jpg|jpeg|gif|ico|woff|woff2|ttf|eot|db|sqlite|pdf|zip|tar|gz)$ ]] && continue

        # Search the staged version of the file
        MATCHES=$(git show ":$file" 2>/dev/null | grep -inE "$PATTERN" 2>/dev/null)

        if [ -n "$MATCHES" ]; then
            if [ "$SEVERITY" == "BLOCK" ]; then
                echo -e "${RED}  [BLOCKED]${NC} ${BOLD}$file${NC}"
                echo -e "    Pattern: ${RED}$PATTERN${NC}"
                echo "$MATCHES" | head -3 | while IFS= read -r match; do
                    echo -e "    ${RED}>>>${NC} $match"
                done
                MATCH_COUNT=$(echo "$MATCHES" | wc -l)
                if [ "$MATCH_COUNT" -gt 3 ]; then
                    echo -e "    ... and $((MATCH_COUNT - 3)) more matches"
                fi
                echo ""
                BLOCKED=$((BLOCKED + 1))
            else
                echo -e "${YELLOW}  [WARNING]${NC} ${BOLD}$file${NC}"
                echo -e "    Pattern: ${YELLOW}$PATTERN${NC}"
                echo "$MATCHES" | head -2 | while IFS= read -r match; do
                    echo -e "    ${YELLOW}>>>${NC} $match"
                done
                echo ""
                WARNINGS=$((WARNINGS + 1))
            fi
        fi
    done

done < "$PATTERNS_FILE"

# ---- SENSITIVE FILE CHECK ----

SENSITIVE_PATTERNS=(".env" ".env.local" ".env.production" ".env.staging" \
    "credentials.json" "secrets.json" "service-account.json" \
    "id_rsa" "id_ed25519" "*.pem" "*.key" "*.p12" "*.pfx" \
    "token.txt" "auth.json" ".npmrc" ".pypirc" ".netrc")

for pattern in "${SENSITIVE_PATTERNS[@]}"; do
    for file in $STAGED_FILES; do
        basename=$(basename "$file")
        if [[ "$basename" == $pattern ]]; then
            echo -e "${RED}  [BLOCKED]${NC} ${BOLD}$file${NC}"
            echo -e "    Reason: ${RED}Sensitive file type ($basename)${NC}"
            echo ""
            BLOCKED=$((BLOCKED + 1))
        fi
    done
done

# ---- SUMMARY ----

echo -e "${BOLD}  -------------------------------------------${NC}"
if [ $BLOCKED -gt 0 ]; then
    echo -e "${RED}${BOLD}  COMMIT BLOCKED${NC}: $BLOCKED issue(s) found."
    echo -e "  Fix the issues above, then try again."
    echo -e "  ${YELLOW}Bypass (emergency only): git commit --no-verify${NC}"
    echo ""
    exit 1
elif [ $WARNINGS -gt 0 ]; then
    echo -e "${YELLOW}${BOLD}  PASSED WITH WARNINGS${NC}: $WARNINGS warning(s)."
    echo ""
    exit 0
else
    echo -e "${GREEN}${BOLD}  CLEAN${NC}: No sensitive data detected."
    echo ""
    exit 0
fi
